{
  "name": "pebble-pixel-pastures",
  "author": "James Downs",
  "version": "1.4.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "dependencies": {
    "pebble-packet": "1.6.0",
    "@rebble/clay": "1.0.8"
  },
  "pebble": {
    "displayName": "Pixel Pastures",
    "uuid": "9f5c5a70-3383-4a1d-b09a-3cc537242890",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite",
      "emery",
      "flint",
      "gabbro"
    ],
    "watchapp": {
      "watchface": true
    },
    "messageKeys": [
      "type",
      "season",
      "weatherCondition",
      "sunriseHour",
      "sunsetHour",
      "temperatureC",
      "temperatureF",
      "SETTINGS_DETAIL_TYPE",
      "SETTINGS_TEMPERATURE_UNIT",
      "SETTINGS_BIRTHDAY"
    ],
    "capabilities": [
      "health",
      "location",
      "configurable"
    ],
    "resources": {
